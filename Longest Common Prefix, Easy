/**
 * @param {string[]} strs
 * @return {string}
 */

var longestCommonPrefix = function (strs) {

    let first = strs[0]
    let result = ""


    for (let i = 0; i < first.length; i++) {

        for (let j = 0; j < strs.length; j++)
            if (strs[j][i] === first[i]){

            } else {
                return result
            }

        result += first[i]

    }

    return result
};

